        //     <span>View my CS and programming projects</span>
        // </a>
        <a href="https://linkedin.com/in/okayjerd" class="link-card">
            <strong>LinkedIn</strong>
            <span>Connect with me professionally</span>
        </a>
    </div>

</body>
</html>
